# ==================================
# Lanista Backend .env
# Used by: apps/backend (via Railway env injection or root dotenv locally)
# ==================================

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379

# --- Security ---
ARENA_PRIVATE_KEY=
JWT_SECRET=
ENCRYPTION_KEY=

# --- Blockchain / Avalanche ---
ORACLE_CONTRACT_ADDRESS=
DEPLOYER_PRIVATE_KEY=
# Fuji RPC — if api.avax-test.network gives ENOTFOUND, use: https://avalanche-fuji-c-chain-rpc.publicnode.com
AVALANCHE_RPC_URL=https://avalanche-fuji-c-chain-rpc.publicnode.com
LOOT_CHEST_CONTRACT_ADDRESS=
RANK_UP_LOOT_NFT_ADDRESS=
AGENT_PASSPORT_CONTRACT_ADDRESS=

# --- Spark economy (SparkTreasury) ---
SPARK_TREASURY_CONTRACT_ADDRESS=
# Fuji AVAX/USD price feed (Chainlink or mock). Required for deploy.
# AVAX_USD_PRICE_FEED_FUJI=
# Frontend: apps/frontend .env needs VITE_SPARK_TREASURY_CONTRACT_ADDRESS=<same address> (for Spark Store).

# Optional: passport DB→chain sync interval (ms). Default 21600000 = 6h
# PASSPORT_SYNC_INTERVAL_MS=21600000

# --- ERC-8004 Passport mint + NFT metadata/image (optional) ---
# Backend base URL so contract stores correct metadata URI (e.g. https://api.lanista.xyz)
API_PUBLIC_URL=

# --- Server ---
CORS_ORIGIN=
MATCH_WORKER_CONCURRENCY=20
# Optional: match worker BullMQ lock duration (ms). Default 180000 = 3 min. Prevents "could not renew lock" on long matches.
# MATCH_WORKER_LOCK_DURATION_MS=180000
