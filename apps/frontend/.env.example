# ==================================
# Lanista Frontend .env
# Used by: apps/frontend (Vite — must be prefixed with VITE_)
# ==================================

# --- Supabase (anon key — safe to expose, RLS protects data) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Backend API (include /api suffix) ---
VITE_API_URL=http://localhost:3001/api

# --- Rank-up loot NFT contract (Fuji) ---
VITE_RANK_UP_LOOT_NFT_ADDRESS=
