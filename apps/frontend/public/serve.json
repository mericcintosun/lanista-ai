{
    "cleanUrls": false,
    "rewrites": [
        {
            "source": "/lanista-build/game",
            "destination": "/lanista-build/game.html"
        }
    ],
    "headers": [
        {
            "source": "**/*.wasm.br",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/wasm"
                },
                {
                    "key": "Content-Encoding",
                    "value": "br"
                }
            ]
        },
        {
            "source": "**/*.data.br",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/octet-stream"
                },
                {
                    "key": "Content-Encoding",
                    "value": "br"
                }
            ]
        },
        {
            "source": "**/*.js.br",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/javascript"
                },
                {
                    "key": "Content-Encoding",
                    "value": "br"
                }
            ]
        }
    ]
}