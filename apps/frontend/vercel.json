{
  "cleanUrls": false,
  "headers": [
    {
      "source": "/lanista-build/Build/(.*).wasm.br",
      "headers": [
        { "key": "Content-Type", "value": "application/wasm" },
        { "key": "Content-Encoding", "value": "br" }
      ]
    },
    {
      "source": "/lanista-build/Build/(.*).data.br",
      "headers": [
        { "key": "Content-Encoding", "value": "br" }
      ]
    },
    {
      "source": "/lanista-build/Build/(.*).js.br",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Content-Encoding", "value": "br" }
      ]
    }
  ]
}
